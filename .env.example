# Copy this file to .env or run: npm run setup

PORT=8082
ACCIO_BASE_URL=http://127.0.0.1:4097

# Optional. Usually auto-generated by `npm run init-env`.
ACCIO_HOME=
ACCIO_ACCOUNT_ID=
ACCIO_AGENT_ID=
ACCIO_WORKSPACE_PATH=
ACCIO_LANGUAGE=
ACCIO_SOURCE_CHANNEL_ID=
ACCIO_SOURCE_CHAT_ID=
ACCIO_SOURCE_USER_ID=
ACCIO_SOURCE_CHAT_TYPE=

ACCIO_SOURCE_PLATFORM=pcApp
ACCIO_SOURCE_TYPE=im
ACCIO_REQUEST_TIMEOUT_MS=120000
ACCIO_TRANSPORT=auto
ACCIO_AUTH_MODE=auto
ACCIO_AUTH_STRATEGY=round_robin
ACCIO_ACCOUNTS_CONFIG_PATH=config/accounts.json
ACCIO_ACCESS_TOKEN=
ACCIO_AUTH_ACCOUNT_ID=env-default
ACCIO_ACCESS_TOKEN_EXPIRES_AT=
ACCIO_GATEWAY_AUTOSTART=1
ACCIO_APP_PATH=/Applications/Accio.app
ACCIO_GATEWAY_WAIT_MS=20000
ACCIO_GATEWAY_POLL_MS=500
ACCIO_DIRECT_LLM_BASE_URL=https://phoenix-gw.alibaba.com/api/adk/llm
ACCIO_MODELS_SOURCE=static
ACCIO_MODELS_CACHE_TTL_MS=30000
ACCIO_MAX_BODY_BYTES=10485760
ACCIO_BODY_READ_TIMEOUT_MS=30000
ACCIO_AUTH_CACHE_TTL_MS=120000
ACCIO_CLIENT_ID_PREFIX=anthropic-bridge
ACCIO_SESSION_STORE_PATH=.data/sessions.json
ACCIO_MAX_RETRIES=2
ACCIO_RETRY_BASE_MS=250
ACCIO_RETRY_MAX_DELAY_MS=2500
